# ══════════════════════════════════════════════════════════════════
# مجلس مستشار أمد للوعي المالي — متغيرات البيئة (On-Premise Edition)
# انسخ هذا الملف إلى .env وعدّل القيم عند الحاجة (كلها اختيارية ولها
# قيم افتراضية منطقية إن لم تُحدَّد).
# ══════════════════════════════════════════════════════════════════

# ─── إعدادات Ollama (الاستدلال المحلي) ────────────────────────────
# عنوان خادم Ollama المحلي (شغّله عبر: ollama serve)
OLLAMA_HOST=http://localhost:11434

# نموذج المحادثة الرئيسي — يجب تنزيله مسبقاً عبر: ollama pull qwen2.5:3b
OLLAMA_MODEL=qwen2.5:3b

# نموذج التضمين (Embeddings) المستخدم في RAG — يجب تنزيله عبر:
# ollama pull nomic-embed-text
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── إعدادات RAG وChromaDB ─────────────────────────────────────────
# مجلد تخزين قاعدة البيانات المتجهة على القرص المحلي
CHROMA_DIR=chroma_store

# عدد المقاطع المسترجعة لكل سؤال من قاعدة معرفة كل وكيل
RAG_TOP_K=4

# حجم المقطع النصي وتداخله عند التقسيط في ingest_data.py (بالأحرف)
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150

# ─── إعدادات الخادم ─────────────────────────────────────────────
PORT=3000
# الحد الأقصى لجولات النقاش المشتركة للمجلس (الافتراضي 1 لتسريع الاستجابة محلياً، أو 2 للنقاش المعمق)
COUNCIL_MAX_ROUNDS=1

